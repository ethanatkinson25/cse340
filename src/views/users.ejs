<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <p>Here are all registered users:</p>
    <ul>
        <% users.forEach(user => { %>
            <li><strong><%= user.name %></strong> - Email: <%= user.email %> - Role: <%= user.role_name %></li>
        <% }); %>
    </ul>
</main>

<%- include('partials/footer') %>