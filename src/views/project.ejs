<%- include('partials/header') %>
    <main>
        <h1><%= project.title %></h1>

        <p><%= project.description %></p>

        <ul>
            <li><strong>Date:</strong> <%= project.date %></li>
            <li><strong>Location:</strong> <%= project.location %></li>
            <li>
                <strong>Organization:</strong>
                <a href="/organization/<%= project.organization_id %>">
                    <%= project.organization_name %>
                </a>
            </li>
        </ul>

        <h3>Categories</h3>
        <% if (typeof categories !== 'undefined' && categories.length) { %>
            <div class="category-tags">
                <% categories.forEach(category => { %>
                    <a href="/category/<%= category.category_id %>" class="category-tag"><%= category.name %></a>
                <% }) %>
            </div>
        <% } else { %>
            <p>No categories assigned.</p>
        <% } %>

        <p><a href="/edit-project/<%= project.project_id %>">Edit Project</a> | <a href="/assign-categories/<%= project.project_id %>">Assign Categories</a></p>
    </main>
    <%- include('partials/footer') %>