<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p>Name: <%= name %></p>
    <p>Username: <%= email %></p>

    <% if (role === 'admin') { %>
        <p><a href="/users">View All Users</a></p>
    <% } %>

    <h2>My Volunteer Projects</h2>
    <% if (typeof volunteerProjects !== 'undefined' && volunteerProjects.length > 0) { %>
        <table border="1" cellpadding="10">
            <thead>
                <tr>
                    <th>Project Title</th>
                    <th>Date</th>
                    <th>Location</th>
                    <th>Organization</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% volunteerProjects.forEach(project => { %>
                    <tr>
                        <td><a href="/project/<%= project.project_id %>"><%= project.title %></a></td>
                        <td><%= project.date %></td>
                        <td><%= project.location %></td>
                        <td><a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></td>
                        <td>
                            <form method="POST" action="/remove-volunteer/<%= project.project_id %>" style="display: inline;">
                                <button type="submit">Remove</button>
                            </form>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p>You are not currently volunteering for any projects. <a href="/projects">View all projects</a> to find one to volunteer for!</p>
    <% } %>

</main>

<%- include('partials/footer') %>

    <% if (isLoggedIn) { %>
    <p><a href="/dashboard">My Dashboard</a></p>
<% } %>
