<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <h2>Service Categories</h2>
        <ul>
            <% if (typeof categories !== 'undefined' && categories.length) { %>
                <% categories.forEach(function(category) { %>
                    <li><%= category.name %></li>
                <% }) %>
            <% } else { %>
                <li>No categories found.</li>
            <% } %>
        </ul>
    </main>
    <%- include('partials/footer') %>