<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <form id="categoryForm" action="/edit-category/<%= category.category_id %>" method="POST">
        <div class="form-group">
            <label for="name">Category Name</label>
            <input
                type="text"
                id="name"
                name="name"
                value="<%= category.name %>"
                required
                maxlength="100"
            />
        </div>

        <button type="submit">Update Category</button>
    </form>

</main>
<%- include('partials/footer') %></content>
